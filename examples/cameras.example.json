{
  "storage_dir": ".camera-mcp/frames",
  "evaluator": {
    "provider": "openai",
    "model": "gpt-4.1-mini",
    "api_key_env": "OPENAI_API_KEY",
    "detail": "low"
  },
  "cameras": [
    {
      "id": "printer-cam",
      "name": "Printer Camera",
      "type": "snapshot_url",
      "url": "http://octopi.local/webcam/?action=snapshot"
    },
    {
      "id": "fixture",
      "name": "Fixture Image",
      "type": "file",
      "path": "examples/fixture.jpg"
    },
    {
      "id": "laptop-camera",
      "name": "Laptop Camera",
      "type": "macos_camera",
      "device_name": "FaceTime HD Camera"
    }
  ]
}
